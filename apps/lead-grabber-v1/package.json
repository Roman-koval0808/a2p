{
	"name": "clearsky-demo",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3005 --host 0.0.0.0",
		"prebuild": "prisma generate && node -e \"const fs = require('fs'); const p = './clearsky-db-client/package.json'; const pkg = JSON.parse(fs.readFileSync(p)); pkg.type = 'commonjs'; fs.writeFileSync(p, JSON.stringify(pkg, null, 2));\"",
		"build": "vite build",
		"postbuild": "pm2 delete lead-grabber-v1 2>/dev/null || true; pm2 start ecosystem.config.cjs",
		"preview": "vite preview --port 3005 --host 0.0.0.0",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "prisma generate && node -e \"const fs = require('fs'); const p = './clearsky-db-client/package.json'; const pkg = JSON.parse(fs.readFileSync(p)); pkg.type = 'commonjs'; fs.writeFileSync(p, JSON.stringify(pkg, null, 2));\"",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^22.15.17",
		"@types/pg": "^8.11.10",
		"@types/ws": "^8.18.1",
		"autoprefixer": "^10.4.20",
		"bits-ui": "1.0.0-next.71",
		"clsx": "^2.1.1",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.45.1",
		"globals": "^15.0.0",
		"lucide-svelte": "^0.462.0",
		"mode-watcher": "^0.5.0",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"prisma": "^5.20.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^0.3.28",
		"tailwind-merge": "^2.5.5",
		"tailwind-variants": "^0.3.0",
		"tailwindcss": "^3.4.9",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.5.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.4.4",
		"vitest": "^2.1.0"
	},
	"dependencies": {
		"@prisma/client": "^5.20.0",
		"@sveltejs/adapter-node": "^5.2.10",
		"@telnyx/webrtc": "^2.27.1",
		"@types/uuid": "^11.0.0",
		"bcryptjs": "^2.4.3",
		"clearsky-db-client": "link:./clearsky-db-client",
		"firebase-admin": "^13.8.0",
		"groq-sdk": "^0.37.0",
		"jose": "^6.1.3",
		"nodemailer": "^6.9.16",
		"openai": "^6.44.0",
		"pg": "^8.13.1",
		"svelte-dnd-action": "^0.9.52",
		"svelte-use-form": "^2.10.0",
		"uuid": "^14.0.0",
		"ws": "^8.18.3",
		"zod": "^4.4.3"
	}
}
