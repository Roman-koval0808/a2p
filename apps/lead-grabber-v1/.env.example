PUBLIC_POCKETBASE_URL=your_pocketbase_url
PUBLIC_ENV=development
PUBLIC_BASE_URL=http://localhost:5173
DATABASE_URL="postgresql://user:password@localhost:5432/lead_grabber?schema=public"
JWT_SECRET=your-secret-key-change-in-production
GROQ_API_KEY=your-groq-api-key
OPEN_AI_KEY=your-openai-api-key
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=
TELNYX_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
# Optional: Telnyx webhook public key (Mission Control > API Keys > Public Key). When set, webhooks are verified (Ed25519). Omit in dev to skip verification.
# TELNYX_PUBLIC_KEY=

# Optional: A2P backend base URL. When set, Telnyx voice and SMS webhooks are forwarded to this backend instead of handled locally.
# AI_BASE_URL=http://localhost:5200
# Optional: A2P email service (port 5100). Defaults to AI_BASE_URL if unset.
# AI_BASE_URL_EMAIL=http://localhost:5100
# Optional: A2P PostgreSQL read-only (comm_events, contacts). When set, communication log page loads from this DB.
# A2P_DATABASE_URL=postgresql://a2p_user:***@localhost:5432/a2p_db
# Optional: A2P comm-log HTTP API (no DB needed). If set, comm log is fetched from this URL instead of DB.
# A2P_COMMLOG_API_URL=http://host:5100/api/comm-events

# Optional: Firebase Admin for FCM (incoming-call push). Base64-encoded service account JSON or single-line JSON. Never commit real values.
# FIREBASE_SERVICE_ACCOUNT_JSON=